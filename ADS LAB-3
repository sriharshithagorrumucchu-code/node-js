#include<iostream>
using namespace std;
int main(){

    int A[] = {2,2,5,-1};
    int tar = 4;
    int n = 4;
    int first,second,sum;
    for(int i = 0;i<n;i++){
	   first = A[i];
       for(int j=i+1;j<n;j++){
	       second = A[j];
           sum = first+second;
           if(sum==tar){
	           cout<<"pairs found at"<<first<<","<<second<<endl;
	           break;
	           
	        }
        }

    }
    return 0;

}
