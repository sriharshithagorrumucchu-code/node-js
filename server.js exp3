const express = require('express');
const app = express();
const PORT = 3000;
const logger    = require('./middleware/logger');
app.use(express.json());
app.use(logger);
app.get('/data',(req, res) => {
    res.json({ info: 'Here is your data' });
});
app.listen(PORT, () => {
    console.log(`Server running on http://localhost:${PORT}`);
});
